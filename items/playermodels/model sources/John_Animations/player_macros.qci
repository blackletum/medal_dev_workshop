	blendwidth 3 blend move_y -1 1 blend move_x -1 1 \\
	addlayer $aimlayer$ \\
	fadein 0.3 fadeout 0.3 loop \\
	node "sprintning" \\
	} \\
$continue $sprintname$

$definemacro makematchsprintB sprintname filename frame aimlayer \\
$animation a_$sprintname$_pose $filename$ frame $frame$ $frame$ \\
$MakeSprintBlends_NoL $sprintname$ SW $filename$ $frame$ \\
$MakeSprintBlends_NoL $sprintname$ S  $filename$ $frame$ \\
$MakeSprintBlends_NoL $sprintname$ SE $filename$ $frame$ \\
$MakeSprintBlends_NoL $sprintname$ W  $filename$ $frame$ \\
