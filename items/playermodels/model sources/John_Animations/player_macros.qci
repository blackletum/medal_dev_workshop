//
// make a bhopglide animation from a composite of an upper body pose and the CS bhopglide
//
$definemacro makebhopglideB bhopglidename filename frame \\
$sequence $bhopglidename$ "fyzure/backhop_loop.smd" { \\
	fps 15 \\
	loop \\
	} \\
$continue $bhopglidename$





$definemacro MakeSprintBlends sprintname direction filename frame \\
$animation a_sprint_$sprintname$_$direction$ valve/male_humans/alternative_sprint/a_Run$direction$ { \\
	LX LY \\
	startloop 0 \\
	alignto reference \\
	weightlist AimlayerWorldSpaceBlend \\
	worldspaceblend a_$sprintname$_pose \\
	weightlist AllBones \\
	fps 40 \\
} \\
$continue a_sprint_$sprintname$_$direction$ \\

$definemacro MakeSprintBlends_NoL sprintname direction filename frame \\
$animation a_sprint_$sprintname$_$direction$ valve/male_humans/alternative_sprint/a_Run$direction$ { \\
	LX LY \\
	startloop 0 \\
	alignto reference \\
	weightlist MakeRunNoLeftArm \\
	worldspaceblend a_$sprintname$_pose \\
	weightlist AllBones \\
	fps 40 \\
} \\
$continue a_sprint_$sprintname$_$direction$ \\

$definemacro makematchsprint sprintname filename frame aimlayer \\
$animation a_$sprintname$_pose $filename$ frame $frame$ $frame$ \\
$MakeSprintBlends $sprintname$ SW $filename$ $frame$ \\
$MakeSprintBlends $sprintname$ S  $filename$ $frame$ \\
$MakeSprintBlends $sprintname$ SE $filename$ $frame$ \\
$MakeSprintBlends $sprintname$ W  $filename$ $frame$ \\
