	loop LX LY startloop 0 rotateto 0
	alignto reference
	fps 30
}
$animation a_UnarmedRunNW "valve\male_humans\alternative_sprint\a_RunNW" { 
	loop LX LY startloop 0 rotateto 45
	alignto reference
	fps 30
}
$animation a_UnarmedRunW "valve\male_humans\alternative_sprint\a_RunW" { 
	loop LX LY startloop 0 rotateto 90
	alignto reference
	fps 30
}
$animation a_UnarmedRunSW "valve\male_humans\alternative_sprint\a_RunSW" { 
	loop LX LY startloop 0 rotateto 135
	alignto reference
	fps 30
}

$makeidle	idle_unarmed		"valve\male_humans\Idle_subtle" 0 head_rot_z_unarmed ACT_MP_STAND_MELEE 1 addlayer idle_tf_layer addlayer head_rot_y_unarmed
$makecidle	cidle_unarmed		"maxofs2d\cidle_all" 0 head_rot_z_unarmed ACT_MP_CROUCH_MELEE 1 addlayer head_rot_y_unarmed 
$makejump	jump_unarmed		"fyzure/jump_all_start" 0 head_rot_z_unarmed ACT_MP_JUMP_MELEE 1 addlayer idle_tf_layer addlayer head_rot_z_unarmed addlayer head_rot_y_unarmed
$makejump	jump_start_unarmed		"fyzure/jump_all_start" 0 head_rot_z_unarmed ACT_MP_JUMP_START_MELEE 1 addlayer idle_tf_layer addlayer head_rot_z_unarmed addlayer head_rot_y_unarmed
