$animation a_idle_tf_layer "fyzure/idlebreathe" subtract a_idle_tf_layer 0
$animation a_idle_hl2_layer "valve\male_humans\idle02" subtract a_idle_hl2_layer 0

$sequence idle_tf_layer a_idle_tf_layer fps 20 iklock rfoot 1 0 iklock lfoot 1 0 delta loop realtime weightlist 50percent
$sequence idle_hl2_layer a_idle_hl2_layer fps 30 iklock rfoot 1 0 iklock lfoot 1 0 delta loop realtime

// crouch walking, no weapon
$animation a_Crouch_walkS "valve\male_humans\Crouch_walkS" {
	loop LX LY rotateto -180
	alignto reference
}
$animation a_Crouch_walkSE "valve\male_humans\Crouch_walkSE" {
	loop LX LY rotateto -135
	alignto reference
}
$animation a_Crouch_walkE "valve\male_humans\Crouch_walkE" { 
	loop LX LY rotateto -90
	alignto reference
}
$animation a_Crouch_walkNE "valve\male_humans\Crouch_walkNE" { 
	loop LX LY rotateto -45
	alignto reference
}
$animation a_Crouch_walkN "valve\male_humans\crouch_walkN" { 
	loop LX LY rotateto 0
	alignto reference
}
$animation a_Crouch_walkC "gordonfreakman\crouch_walkNInPlace" { 
	loop LX LY rotate 0
	alignto reference
}
$animation a_Crouch_walkNW "valve\male_humans\Crouch_walkNW" { 
	loop LX LY rotateto 45
	alignto reference
}
$animation a_Crouch_walkW "valve\male_humans\Crouch_walkW" { 
	loop LX LY rotateto 90
	alignto reference
}
$animation a_Crouch_walkSW "valve\male_humans\Crouch_walkSW" { 
	loop LX LY rotateto 135
	alignto reference
}

// running, no weapon
$animation a_RunS "valve\male_humans\RunS" { 
	loop LX LY startloop 0 rotateto -180
	alignto reference
}
$animation a_RunSE "valve\male_humans\RunSE" { 
	loop LX LY startloop 0 rotateto -135
	alignto reference
}
$animation a_RunE "valve\male_humans\RunE" { 
	loop LX LY startloop 0 rotateto -90
	alignto reference
}
$animation a_RunNE "valve\male_humans\RunNE" { 
	loop LX LY startloop 0 rotateto -45
	alignto reference
}
$animation a_RunN "valve\male_humans\RunN" { 
	loop LX LY startloop 0 rotateto 0
	alignto reference
}
$animation a_RunC "valve\male_humans\idle_subtle" { 
	loop startloop 0
	alignto reference
}
$animation a_RunNW "valve\male_humans\RunNW" { 
	loop LX LY startloop 0 rotateto 45
	alignto reference
}
$animation a_RunW "valve\male_humans\RunW" { 
	loop LX LY startloop 0 rotateto 90
	alignto reference
}
$animation a_RunSW "valve\male_humans\RunSW" { 
	loop LX LY startloop 0 rotateto 135
	alignto reference
}

$animation "a_head_rot_z_lt_corrective_animation" "maxofs2d\a_head_rot_z_lt_corrective_animation.smd" {
	fps 30
	ikrule "rhand" release contact 0 fakeorigin 0 0 0 fakerotate 0 0 0 floor 0 height 0 radius 0 range 0 0 0 0 target 0
	ikrule "lhand" release contact 0 fakeorigin 0 0 0 fakerotate 0 0 0 floor 0 height 0 radius 0 range 0 0 0 0 target 1
	ikrule "rfoot" release contact 0 fakeorigin 0 0 0 fakerotate 0 0 0 floor 0 height 0 radius 0 range 0 0 0 0 target 2
	ikrule "lfoot" release contact 0 fakeorigin 0 0 0 fakerotate 0 0 0 floor 0 height 0 radius 0 range 0 0 0 0 target 3
}

