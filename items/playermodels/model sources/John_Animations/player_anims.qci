$animation a_UnarmedRunS "valve\male_humans\alternative_sprint\a_RunS" { 
	loop LX LY startloop 0 rotateto -180
	alignto reference
	fps 30
}
$animation a_UnarmedRunSE "valve\male_humans\alternative_sprint\a_RunSE" { 
	loop LX LY startloop 0 rotateto -135
	alignto reference
	fps 30
}
