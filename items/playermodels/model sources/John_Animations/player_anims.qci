$weightlist armsblendstun {
	"ValveBiped.Bip01_Pelvis" 1.0
}
//--------------------------------------------------------
//primary stun layers
//--------------------------------------------------------
$sequence layer_PRIMARY_Stun_begin "fyzure\stun_begin.smd" weightlist armsblendstun {
	hidden
}

$sequence layer_PRIMARY_stun_middle "fyzure\stun_middle.smd" weightlist armsblendstun {
	hidden
}

$sequence layer_PRIMARY_Stun_end "fyzure\stun_end.smd" weightlist armsblendstun {
	hidden
}

$animation a_stun_startpose "fyzure\stun_begin.smd" frames 0 0

$animation a_stun_endpose "fyzure\stun_end.smd" frames 20 20

//------------------------------------
//primary stun
//------------------------------------
$sequence PRIMARY_Stun_begin {
	"fyzure\stun_begin.smd"
	snap
	subtract a_stun_startpose 0
	delta
	ikrule lhand release
	ikrule rhand release
 	blendlayer layer_PRIMARY_Stun_begin 0 7 25 25
 	activity ACT_MP_STUN_BEGIN 1
}

$sequence PRIMARY_stun_middle {
	"fyzure\stun_middle.smd"
	snap
	subtract a_stun_startpose 0
	delta
	ikrule lhand release
	ikrule rhand release
	addlayer layer_PRIMARY_stun_middle
 	activity ACT_MP_STUN_MIDDLE 1
}

$sequence PRIMARY_stun_end {
	"fyzure\stun_end.smd"
	snap
	subtract a_stun_startpose 0
	delta
	ikrule lhand release
	ikrule rhand release
	blendlayer layer_PRIMARY_Stun_end 0 0 10 21
 	activity ACT_MP_STUN_END 1
}

$sequence taunt01 "valve\male_humans\WeaponAnims_Shared\shotgun1_reload.smd" frames 40 75

// sprinting, no weapon
$animation a_SprintS "valve\male_humans\alternative_sprint\a_RunS" { 
	loop LX LY startloop 0 rotateto -180
	alignto reference
	fps 40
}
$animation a_SprintSE "valve\male_humans\alternative_sprint\a_RunSE" { 
	loop LX LY startloop 0 rotateto -135
	alignto reference
	fps 40
}
$animation a_SprintE "valve\male_humans\alternative_sprint\a_RunE" { 
	loop LX LY startloop 0 rotateto -90
	alignto reference
	fps 40
}
$animation a_SprintNE "valve\male_humans\alternative_sprint\a_RunNE" { 
	loop LX LY startloop 0 rotateto -45
	alignto reference
	fps 40
}
$animation a_SprintN "valve\male_humans\alternative_sprint\a_RunN" { 
	loop LX LY startloop 0 rotateto 0
	alignto reference
	fps 40
}
$animation a_SprintNW "valve\male_humans\alternative_sprint\a_RunNW" { 
	loop LX LY startloop 0 rotateto 45
	alignto reference
	fps 40
}
$animation a_SprintW "valve\male_humans\alternative_sprint\a_RunW" { 
	loop LX LY startloop 0 rotateto 90
	alignto reference
	fps 40
}
$animation a_SprintSW "valve\male_humans\alternative_sprint\a_RunSW" { 
	loop LX LY startloop 0 rotateto 135
	alignto reference
	fps 40
}

$sequence Sprint_all {
	a_SprintSW a_SprintS a_SprintSE
	a_SprintW a_runC a_SprintE
	a_SprintNW a_SprintN a_SprintNE
	blendwidth 3 blend move_y -1 1 blend move_x -1 1
	ACT_HL2MP_SPRINT 1 node "running"
}

