$animation "a_head_rot" "maxofs2d\a_head_rot.smd" {
	fps 30
	// Crowbar writes this subtract option to prevent jigglebone and poseparameter problems when delta sequences are recompiled.
	subtract "a_head_rot_corrective_animation" 0
	weightlist "weights_head_rot_z"
}

$animation "a_head_rot_lt" "maxofs2d\a_head_rot_lt.smd" {
	fps 30
	// Crowbar writes this subtract option to prevent jigglebone and poseparameter problems when delta sequences are recompiled.
	subtract "a_head_rot_lt_corrective_animation" 0
	weightlist "weights_head_rot_z"
}

$animation "a_head_rot_rt" "maxofs2d\a_head_rot_rt.smd" {
	fps 30
	// Crowbar writes this subtract option to prevent jigglebone and poseparameter problems when delta sequences are recompiled.
	subtract "a_head_rot_rt_corrective_animation" 0
	weightlist "weights_head_rot_z"
}

$animation "a_head_rot_dwn" "maxofs2d\a_head_rot_dwn.smd" {
	fps 30
	// Crowbar writes this subtract option to prevent jigglebone and poseparameter problems when delta sequences are recompiled.
	subtract "a_head_rot_dwn_corrective_animation" 0
	weightlist "weights_head_rot_z"
}

$animation "a_head_rot_up" "maxofs2d\a_head_rot_up.smd" {
	fps 30
	// Crowbar writes this subtract option to prevent jigglebone and poseparameter problems when delta sequences are recompiled.
	subtract "a_head_rot_up_corrective_animation" 0
	weightlist "weights_head_rot_z"
}

$animation "a_head_rot_z_rt" "maxofs2d\a_head_rot_z_rt.smd" {
	fps 30
	// Crowbar writes this subtract option to prevent jigglebone and poseparameter problems when delta sequences are recompiled.
	subtract "a_head_rot_z_rt_corrective_animation" 0
	weightlist "weights_head_rot_z"
}

$animation "a_head_rot_z_lt" "maxofs2d\a_head_rot_z_lt.smd" {
	fps 30
	// Crowbar writes this subtract option to prevent jigglebone and poseparameter problems when delta sequences are recompiled.
	subtract "a_head_rot_z_lt_corrective_animation" 0
	weightlist "weights_head_rot_z"
}

$sequence "head_rot_z_unarmed" {
	"a_head_rot_z_rt"
	"a_head_rot"
	"a_head_rot_z_lt"
	autoplay
	blend "body_yaw" 100 -100
	blendwidth 3
	delta
	fadein 0.2
	fadeout 0.2
	hidden
}

$sequence "head_rot_y_unarmed" {
	"a_head_rot_up"
	"a_head_rot"
	"a_head_rot_dwn"
	autoplay
	blend "body_pitch" 100 -100
	blendwidth 3
	delta
	fadein 0.2
	fadeout 0.2
	hidden
}

$sequence crouch_walk_lose {
	a_crouch_walkSW a_crouch_walkS a_crouch_walkSE
	a_crouch_walkW  a_crouch_walkC a_crouch_walkE
	a_crouch_walkNW a_crouch_walkN a_crouch_walkNE
	blendwidth 3 blend move_y -1 1 blend move_x -1 1
	ACT_HL2MP_WALK_CROUCH_LOSERSTATE 1 node "walking"
}

$sequence run_all {
	a_runSW a_runS a_runSE
	a_runW a_runC a_runE
	a_runNW a_runN a_runNE
	blendwidth 3 blend move_y -1 1 blend move_x -1 1
	ACT_HL2MP_RUN 1 node "running"
}

// build weapon aim layers

$makeaimlayer police_WalkN_pistol_aim_matrix	"valve\combine\police\WalkN_pistol_aim_matrix" 
$makeaimlayer weapons_Pistol_aim_matrix			"valve\male_humans\WeaponAnims_Shared\Pistol_aim_matrix"
$makeaimlayerD HL2DM_crouch_aim_pistol			"valve\HL2DM_crouch_aim_pistol"

$makeaimlayer soldier_Aim_9_directions			"valve\combine\Aim_9_directions"
$makeaimlayer soldier_Aim_9_directions_SG		"valve\combine\Aim_9_directions_SG"
$makeaimlayer soldier_Crouch_aim_9_directions	"valve\combine\Crouch_aim_9_directions"
$makeaimlayer weapons_Aim_9_directions			"valve\male_humans\WeaponAnims_Shared\Aim_9_directions"
$makeaimlayer weapons_Aim_9_directions_Alert	"valve\male_humans\WeaponAnims_Shared\Aim_9_directions_Alert"
$makeaimlayerC weapons_RunN_SMG1_Aim_9_directions "valve\male_humans\WeaponAnims_Shared\RunN_SMG1_Aim_9_directions"
$makeaimlayer weapons_WalkN_SMG1_Alert_Aim_9_directions "valve\male_humans\WeaponAnims_Shared\WalkN_SMG1_Alert_Aim_9_directions"

$makeaimlayer weapons_Aim_RPG_9_directions		"valve\male_humans\WeaponAnims_Shared\Aim_RPG_9_directions"
$makeaimlayerD HL2DM_crouch_aim_RPG				"valve\HL2DM_crouch_aim_RPG"

$makeaimlayerD HL2DM_Aim_Gravgun					"valve\HL2DM_Aim_Gravgun"
$makeaimlayerC HL2DM_Run_Aim_Gravgun				"valve\HL2DM_Run_Aim_Gravgun"
$makeaimlayerD HL2DM_crouch_aim_gravgun			"valve\HL2DM_crouch_aim_gravgun"

//my aimlayers

$makeaimlayer fyzure_aimlayer_gravgun		"fyzure\gravgun_aimlayer"
$makeaimlayer_noL fyzure_aimlayer_melee		"fyzure\melee_aimlayer"
$makeaimlayer_noL fyzure_aimlayer_grenade	"fyzure\grenade_aimlayer"
$makeaimlayer fyzure_aimlayer_pistol	"fyzure\pistol_aimlayer"
$makeaimlayer fyzure_aimlayer_crossbow	"fyzure\crossbow_aimlayer"

//gm aimlayers
$makeaimlayer g_aimlayer_ar2	"maxofs2d\aimlayer_ar2"
$makeaimlayer g_aimlayer_ar2_crouch	"maxofs2d\aimlayer_ar2"
$makeaimlayer g_aimlayer_shotgun	"maxofs2d\aimlayer_shotgun"
$makeaimlayer g_aimlayer_smg	"maxofs2d\aimlayer_smg"
$makeaimlayer_twohanded g_aimlayer_melee2             "maxofs2d\aimlayer_melee2.smd"
