$makejump	glide_unarmed		"fyzure/jump_all_start" 0 head_rot_z_unarmed ACT_MP_AIRWALK_MELEE 1 addlayer idle_tf_layer addlayer head_rot_z_unarmed addlayer head_rot_y_unarmed

$sequence run_unarmed {
	a_UnarmedRunSW a_UnarmedRunS a_UnarmedRunSE
	a_UnarmedRunW valve\male_humans\idle_subtle a_UnarmedRunE
	a_UnarmedRunNW a_UnarmedRunN a_UnarmedRunNE
	blendwidth 3 blend move_y -1 1 blend move_x -1 1
	addlayer "head_rot_z_unarmed"
	addlayer "head_rot_y_unarmed"
	ACT_MP_RUN_MELEE 1 node "running"
}

$sequence crouch_walk_unarmed {
	a_crouch_walkSW a_crouch_walkS a_crouch_walkSE
	a_crouch_walkW  a_crouch_walkC a_crouch_walkE
	a_crouch_walkNW a_crouch_walkN a_crouch_walkNE
	blendwidth 3 blend move_y -1 1 blend move_x -1 1
	ACT_MP_CROUCHWALK_MELEE 1 node "walking"
}

